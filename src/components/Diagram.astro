---
// Inline SVG — voice-AI pipeline. Colours use the palette hexes directly.
// All labels are passed in (localizable) via the `nodes` object so the diagram
// reads correctly in both EN and DE.
import type { Content } from '../i18n/types';
interface Props {
  caption: string;
  a11yDesc: string;
  nodes: Content['diagram']['nodes'];
}
const { caption, a11yDesc, nodes: n } = Astro.props;
---
<figure class="diagram-wrap">
<svg viewBox="0 0 1000 460" role="img" aria-labelledby="diag-title diag-desc" xmlns="http://www.w3.org/2000/svg">
  <title id="diag-title">{caption}</title>
  <desc id="diag-desc">{a11yDesc}</desc>
  <defs>
    <linearGradient id="gw-accent" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#69d7a7"/>
      <stop offset="1" stop-color="#2f9c72"/>
    </linearGradient>
    <marker id="arrow" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M0,0 L8,4 L0,8 z" fill="#3a4a40"/>
    </marker>
  </defs>

  <rect x="0" y="0" width="1000" height="460" fill="none"/>

  <!-- row 1: pipeline -->
  <g font-family="ui-monospace, monospace" font-size="15">
    <g>
      <rect x="20" y="40" width="150" height="90" rx="12" fill="#121714" stroke="#1f2a23"/>
      <text x="95" y="78" text-anchor="middle" fill="#e6ece6" font-size="15">{n.caller}</text>
      <text x="95" y="100" text-anchor="middle" fill="#8b97a0" font-size="12">{n.callerSub}</text>
    </g>
    <g>
      <rect x="200" y="40" width="150" height="90" rx="12" fill="#121714" stroke="#1f2a23"/>
      <text x="275" y="72" text-anchor="middle" fill="#e6ece6" font-size="15">{n.stt}</text>
      <text x="275" y="94" text-anchor="middle" fill="#8b97a0" font-size="12">{n.sttSub}</text>
    </g>
    <g>
      <rect x="380" y="40" width="190" height="90" rx="12" fill="url(#gw-accent)"/>
      <text x="475" y="72" text-anchor="middle" fill="#04120c" font-size="15" font-weight="700">{n.orchestration}</text>
      <text x="475" y="94" text-anchor="middle" fill="#04120c" font-size="12">{n.orchestrationSub}</text>
    </g>
    <g>
      <rect x="600" y="40" width="150" height="90" rx="12" fill="#121714" stroke="#1f2a23"/>
      <text x="675" y="72" text-anchor="middle" fill="#e6ece6" font-size="15">{n.tts}</text>
      <text x="675" y="94" text-anchor="middle" fill="#8b97a0" font-size="12">{n.ttsSub}</text>
    </g>
    <g>
      <rect x="780" y="40" width="200" height="90" rx="12" fill="#121714" stroke="#1f2a23"/>
      <text x="880" y="72" text-anchor="middle" fill="#e6ece6" font-size="15">{n.reply}</text>
      <text x="880" y="94" text-anchor="middle" fill="#8b97a0" font-size="12">{n.replySub}</text>
    </g>
  </g>

  <!-- arrows row 1 -->
  <g stroke="#3a4a40" stroke-width="2" fill="none" marker-end="url(#arrow)">
    <line x1="170" y1="85" x2="200" y2="85"/>
    <line x1="350" y1="85" x2="380" y2="85"/>
    <line x1="570" y1="85" x2="600" y2="85"/>
    <line x1="750" y1="85" x2="780" y2="85"/>
  </g>

  <!-- row 2: support -->
  <g font-family="ui-monospace, monospace">
    <g>
      <rect x="200" y="190" width="190" height="80" rx="12" fill="#121714" stroke="#1f2a23"/>
      <text x="295" y="222" text-anchor="middle" fill="#e6ece6" font-size="14">{n.kb}</text>
      <text x="295" y="242" text-anchor="middle" fill="#8b97a0" font-size="11">{n.kbSub}</text>
    </g>
    <g>
      <rect x="430" y="190" width="190" height="80" rx="12" fill="#121714" stroke="#1f2a23"/>
      <text x="525" y="222" text-anchor="middle" fill="#e6ece6" font-size="14">{n.crm}</text>
      <text x="525" y="242" text-anchor="middle" fill="#8b97a0" font-size="11">{n.crmSub}</text>
    </g>
    <g>
      <rect x="660" y="190" width="190" height="80" rx="12" fill="#121714" stroke="#1f2a23"/>
      <text x="755" y="222" text-anchor="middle" fill="#e6ece6" font-size="14">{n.quality}</text>
      <text x="755" y="242" text-anchor="middle" fill="#8b97a0" font-size="11">{n.qualitySub}</text>
    </g>
  </g>

  <!-- arrows to support row -->
  <g stroke="#3a4a40" stroke-width="2" fill="none" marker-end="url(#arrow)" stroke-dasharray="4 4">
    <line x1="475" y1="130" x2="475" y2="186"/>
    <line x1="295" y1="190" x2="460" y2="150"/>
    <line x1="755" y1="190" x2="490" y2="150"/>
  </g>
</svg>
  <figcaption class="diagram-cap">{caption}</figcaption>
</figure>
